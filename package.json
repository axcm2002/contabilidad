{
  "name": "procesador-facturas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:backend": "node --watch server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build": "cd frontend && npm run build && cd .. && rm -rf public && cp -r frontend/dist public",
    "install:frontend": "cd frontend && npm install",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
